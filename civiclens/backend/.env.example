# =============================================================
#  NAGRIK360 — Environment Variables
#  Copy this file to .env and fill in your real values.
#  Never commit .env to git (it's in .gitignore already).
# =============================================================

# ---- Server ----
PORT=5000
NODE_ENV=development
# In production, set this to your Vercel frontend URL (used for CORS).
# Example: https://nagrik360.vercel.app
CLIENT_URL=http://localhost:5500

# ---- Database (PostgreSQL) ----
# Get a free Postgres URL from Render, Supabase, or Neon.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/nagrik360
# Set to false for local Postgres (usually no SSL locally).
# Set to true for any cloud Postgres (Render, Supabase, Neon).
PGSSL=false

# ---- Auth (JWT) ----
# Use a long random string. Generate one with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Groq AI ----
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Cloudinary (photo storage) ----
# Why Cloudinary? Free 25GB storage + 25GB bandwidth, no credit card needed.
# Photos are auto-optimised and served via CDN worldwide.
#
# HOW TO GET YOUR CREDENTIALS (takes 2 minutes):
#   1. Go to https://cloudinary.com/users/register_free
#   2. Sign up with just your email — no credit card asked
#   3. After signup you land on the dashboard home page
#   4. You will see your Cloud Name, API Key, and API Secret
#      right there on the screen — copy all three below.
#
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Max upload size in MB per photo
MAX_FILE_SIZE_MB=8

# ---- Email (SMTP) — for forwarding reports to government ----
# Without this, the app runs in "simulated mode" — the full flow still works
# and generates a reference ID, it just logs instead of actually sending email.
#
# Quick option: Gmail + App Password
#   1. Enable 2FA on your Gmail account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Generate a password for "Mail" → copy the 16 characters
#
GOV_REPORT_EMAIL=grievance@your-city-municipal.gov.in
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=Nagrik360 Alerts <alerts@nagrik360.app>

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX_REQUESTS=100
