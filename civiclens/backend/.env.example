# =============================================================
#  NAGRIK360 — Environment Variables
#  Copy this file to .env and fill in your real values.
#  Never commit .env to git (it's in .gitignore already).
# =============================================================

# ---- Server ----
PORT=5000
NODE_ENV=development
# In production, set this to your Vercel frontend URL (used for CORS).
# Example: https://nagrik360.vercel.app
CLIENT_URL=http://localhost:5500

# ---- Database (PostgreSQL) ----
# Get a free Postgres URL from Render, Supabase, or Neon.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/nagrik360
# Set to false if your local Postgres does not have SSL enabled.
# Keep true for any cloud Postgres (Render, Supabase, Neon).
PGSSL=false

# ---- Auth (JWT) ----
# Use a long random string. Generate one with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Groq AI ----
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Cloudflare R2 (photo storage) ----
# Why R2? S3-compatible API, zero egress fees, generous free tier (10GB / 1M requests/month).
#
# STEP 1 — Create R2 bucket:
#   Cloudflare dashboard → R2 Object Storage → Create bucket
#   Bucket name: nagrik360-uploads
#
# STEP 2 — Enable public access:
#   Open your bucket → Settings → Public Access → Allow Access
#   Copy the "Public R2.dev Bucket URL" shown (e.g. https://pub-xxxxx.r2.dev)
#
# STEP 3 — Create API token:
#   R2 overview page → Manage R2 API Tokens → Create API Token
#   Permission: Object Read & Write  |  Scope: nagrik360-uploads bucket
#   Copy the Access Key ID, Secret Access Key, and Endpoint URL.

# Always "auto" for R2 — do not change this.
R2_REGION=auto

# From "Manage R2 API Tokens" page — Access Key ID
R2_ACCESS_KEY_ID=your_r2_access_key_id

# From "Manage R2 API Tokens" page — Secret Access Key
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Your bucket name (must match what you created in Step 1)
R2_BUCKET=nagrik360-uploads

# From "Manage R2 API Tokens" → Endpoint URL
# Format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# From Step 2 above — the public r2.dev URL for your bucket
# Format: https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev

# Max upload size in MB per photo
MAX_FILE_SIZE_MB=8

# ---- Email (SMTP) — for forwarding reports to government ----
# Without this, the app runs in "simulated mode" — the full flow still works
# and generates a reference ID, it just logs instead of actually sending email.
#
# Quick option: Gmail + App Password
#   Enable 2FA → Google Account → Security → App Passwords → Generate
#
# Production option: SendGrid / Mailgun (same fields, no code change needed)
GOV_REPORT_EMAIL=grievance@your-city-municipal.gov.in
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=Nagrik360 Alerts <alerts@nagrik360.app>

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX_REQUESTS=100
