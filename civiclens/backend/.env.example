# ===========================================
# NAGRIK360 — ENVIRONMENT CONFIGURATION
# Copy this file to ".env" and fill in real values.
# NEVER commit your actual .env file to git.
# ===========================================

# ---- Server ----
PORT=5000
NODE_ENV=production
CLIENT_URL=https://your-frontend.vercel.app

# ---- Groq AI (https://console.groq.com/keys) ----
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Database (Postgres — e.g. Render Postgres, Supabase, Neon) ----
DATABASE_URL=postgres://user:password@host:5432/dbname
# Set to "false" only if your provider's connection string already disables SSL
PGSSL=true

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- File Upload (S3) ----
MAX_FILE_SIZE_MB=8
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET=nagrik360-uploads
# Optional: only needed if fronting the bucket with CloudFront / custom domain,
# or using an S3-compatible provider (R2/B2/MinIO)
S3_PUBLIC_BASE_URL=
S3_ENDPOINT=

# ---- Government Report Routing (email/API) ----
GOV_REPORT_EMAIL=grievance-cell@example-municipal.gov.in
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Nagrik360 Civic Alerts <alerts@nagrik360.app>"

# ---- Optional: Open-Meteo Air Quality API (no key needed, used as-is) ----
AQI_API_BASE=https://air-quality-api.open-meteo.com/v1/air-quality

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX_REQUESTS=100
